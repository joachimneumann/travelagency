KEYCLOAK_ENABLED=true
KEYCLOAK_BASE_URL=http://localhost:8081
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=asiatravelplan-backend
KEYCLOAK_CLIENT_SECRET=replace-with-local-keycloak-client-secret
KEYCLOAK_REDIRECT_URI=http://localhost:8787/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:8080/index.html
KEYCLOAK_ALLOWED_ROLES=atp_admin,atp_manager,atp_accountant,atp_staff

BACKEND_PORT=8787
FRONTEND_PORT=8080
FRONTEND_BIND=127.0.0.1
BACKEND_BASE=http://127.0.0.1:8787
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080
RETURN_TO_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8787,http://127.0.0.1:8787

WHATSAPP_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_WABA_ID=replace-with-whatsapp-waba-id
WHATSAPP_WEBHOOK_ENABLED=true
WHATSAPP_VERIFY_TOKEN=replace-with-whatsapp-verify-token
WHATSAPP_APP_SECRET=replace-with-whatsapp-app-secret

GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/to/gmail-service-account.json
GOOGLE_IMPERSONATED_EMAIL=info@asiatravelplan.com
#OPENAI_TRANSLATION_MODEL=gpt-5.4-mini
#OPENAI_PROJECT_ID=replace
#OPENAI_API_KEY=replace

TRAVELER_DETAILS_TOKEN_SECRET=local-traveler-details-token-secret
TRAVELER_DETAILS_TOKEN_TTL_SECONDS=86400
