{
  email info@asiatravelplan.com
}

(security_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

(noindex_headers) {
  header {
    X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex"
  }
}

asiatravelplan.com {
  import security_headers
  encode zstd gzip
  root * /srv/production

  @manifest path /site.webmanifest
  header @manifest Content-Type "application/manifest+json"

  file_server
}

www.asiatravelplan.com {
  import security_headers
  redir https://asiatravelplan.com{uri} permanent
}

staging.asiatravelplan.com {
  import security_headers
  import noindex_headers
  encode zstd gzip
  root * /srv

  @site_root path /
  rewrite @site_root /frontend/pages/index.html

  @html_pages path /index.html /404.html /backend.html /booking.html /people.html /tour.html /customer.html /group.html
  rewrite @html_pages /frontend/pages{path}

  @staging_access path /staging-access/*
  handle @staging_access {
    reverse_proxy backend:8787
  }

  @protected not path /staging-access/* /api/whatsapp/webhook /integrations/meta/webhook /site.webmanifest
  forward_auth @protected backend:8787 {
    uri /staging-access/check
  }

  @robots path /robots.txt
  rewrite @robots /robots-staging.txt

  @backend path /auth/* /api/* /public/v1/* /integrations/*
  handle @backend {
    reverse_proxy backend:8787
  }

  @manifest path /site.webmanifest
  header @manifest Content-Type "application/manifest+json"

  file_server {
    hide /srv/.git /srv/.gitignore /srv/backend /srv/deploy /srv/documentation /srv/scripts /srv/docker-compose*.yml /srv/.env* /srv/README* /srv/AGENTS.md
  }
}

api-staging.asiatravelplan.com {
  import security_headers
  import noindex_headers
  encode zstd gzip
  reverse_proxy backend:8787
}

auth-staging.asiatravelplan.com {
  import security_headers
  import noindex_headers
  encode zstd gzip
  reverse_proxy keycloak:8080
}
