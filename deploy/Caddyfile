{
  email info@asiatravelplan.com
}

(security_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

(noindex_headers) {
  header {
    X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex"
  }
}

(staging_html_no_cache_headers) {
  @staging_html path / /index.html /404.html /bookings.html /booking.html /persons.html /marketing_tour.html /marketing_tours.html /standard-tours.html /standard-tour.html /settings.html /emergency.html /privacy.html /traveler-details.html
  header @staging_html {
    Cache-Control "no-store, no-cache, must-revalidate"
    Pragma "no-cache"
    Expires "0"
  }
}

(staging_static_cache_headers) {
  @staging_static {
    path /assets/* /frontend/scripts/* /frontend/data/* /frontend/Generated/* /shared/* /site.webmanifest
    not path /frontend/data/generated/homepage/*
  }
  header @staging_static Cache-Control "public, max-age=300, stale-while-revalidate=600, must-revalidate"
}

(staging_generated_homepage_no_cache_headers) {
  @staging_generated_homepage path /frontend/data/generated/homepage/*
  header @staging_generated_homepage {
    Cache-Control "no-store, no-cache, must-revalidate"
    Pragma "no-cache"
    Expires "0"
  }
}

(production_html_no_cache_headers) {
  @production_html path / /index.html /404.html /app-home.html /bookings.html /booking.html /persons.html /marketing_tour.html /marketing_tours.html /standard-tours.html /standard-tour.html /settings.html /emergency.html /privacy.html /traveler-details.html
  header @production_html {
    Cache-Control "no-store, no-cache, must-revalidate"
    Pragma "no-cache"
    Expires "0"
  }
}

(production_static_cache_headers) {
  @production_static {
    path /assets/* /frontend/scripts/* /frontend/data/* /frontend/Generated/* /shared/* /site.webmanifest /robots.txt /sitemap.xml
    not path /frontend/data/generated/homepage/*
  }
  header @production_static Cache-Control "public, max-age=300, stale-while-revalidate=600, must-revalidate"
}

(production_generated_homepage_no_cache_headers) {
  @production_generated_homepage path /frontend/data/generated/homepage/*
  header @production_generated_homepage {
    Cache-Control "no-store, no-cache, must-revalidate"
    Pragma "no-cache"
    Expires "0"
  }
}

asiatravelplan.com {
  import security_headers
  import production_html_no_cache_headers
  import production_static_cache_headers
  import production_generated_homepage_no_cache_headers
  encode zstd gzip

  handle_errors {
    @page_not_found expression {err.status_code} == 404
    handle @page_not_found {
      root * /production-app
      rewrite * /frontend/pages/404.html
      file_server {
        hide /production-app/.git /production-app/.gitignore /production-app/backend /production-app/deploy /production-app/documentation /production-app/scripts /production-app/docker-compose*.yml /production-app/.env* /production-app/README* /production-app/AGENTS.md
      }
    }
  }

  @site_root path /
  handle @site_root {
    root * /production-app
    rewrite * /frontend/pages/index.html
    file_server {
      hide /production-app/.git /production-app/.gitignore /production-app/backend /production-app/deploy /production-app/documentation /production-app/scripts /production-app/docker-compose*.yml /production-app/.env* /production-app/README* /production-app/AGENTS.md
    }
  }

  @legacy_backend_page path /backend.html
  handle @legacy_backend_page {
    redir * /bookings.html 302
  }

  @legacy_marketing_tours_page path /tours.html
  handle @legacy_marketing_tours_page {
    redir * /marketing_tours.html 302
  }

  @legacy_marketing_tour_page path /tour.html
  handle @legacy_marketing_tour_page {
    redir * /marketing_tour.html 302
  }

  @legacy_authenticated_home path /app-home.html
  handle @legacy_authenticated_home {
    redir * / 302
  }

  @production_public_html_pages path /index.html /404.html /privacy.html /traveler-details.html
  handle @production_public_html_pages {
    root * /production-app
    rewrite * /frontend/pages{path}
    file_server {
      hide /production-app/.git /production-app/.gitignore /production-app/backend /production-app/deploy /production-app/documentation /production-app/scripts /production-app/docker-compose*.yml /production-app/.env* /production-app/README* /production-app/AGENTS.md
    }
  }

  @production_backend_html_pages path /bookings.html /booking.html /persons.html /marketing_tour.html /marketing_tours.html /standard-tours.html /standard-tour.html /settings.html /emergency.html
  forward_auth @production_backend_html_pages host.docker.internal:8788 {
    uri /backend-access/check
  }
  handle @production_backend_html_pages {
    root * /production-app
    rewrite * /frontend/pages{path}
    file_server {
      hide /production-app/.git /production-app/.gitignore /production-app/backend /production-app/deploy /production-app/documentation /production-app/scripts /production-app/docker-compose*.yml /production-app/.env* /production-app/README* /production-app/AGENTS.md
    }
  }

  @production_app_static path /assets/* /frontend/scripts/* /frontend/data/* /frontend/Generated/* /shared/* /site.webmanifest /robots.txt /sitemap.xml
  handle @production_app_static {
    root * /production-app
    file_server {
      hide /production-app/.git /production-app/.gitignore /production-app/backend /production-app/deploy /production-app/documentation /production-app/scripts /production-app/docker-compose*.yml /production-app/.env* /production-app/README* /production-app/AGENTS.md
    }
  }

  @production_backend path /auth/* /api/* /public/v1/* /integrations/*
  handle @production_backend {
    reverse_proxy host.docker.internal:8788
  }

  @production_keycloak path /keycloak/*
  handle @production_keycloak {
    reverse_proxy host.docker.internal:8082
  }

  @manifest path /site.webmanifest
  header @manifest Content-Type "application/manifest+json"

  respond 404
}

www.asiatravelplan.com {
  import security_headers
  redir https://asiatravelplan.com{uri} permanent
}

staging.asiatravelplan.com {
  import security_headers
  import noindex_headers
  import staging_html_no_cache_headers
  import staging_static_cache_headers
  import staging_generated_homepage_no_cache_headers
  encode zstd gzip
  root * /srv

  handle_errors {
    @page_not_found expression {err.status_code} == 404
    rewrite @page_not_found /frontend/pages/404.html
    file_server
  }

  @site_root path /
  handle @site_root {
    rewrite * /frontend/pages/index.html
    file_server
  }

  @legacy_backend_page path /backend.html
  handle @legacy_backend_page {
    redir * /bookings.html 302
  }

  @legacy_marketing_tours_page path /tours.html
  handle @legacy_marketing_tours_page {
    redir * /marketing_tours.html 302
  }

  @legacy_marketing_tour_page path /tour.html
  handle @legacy_marketing_tour_page {
    redir * /marketing_tour.html 302
  }

  @persons_page path /persons.html
  handle @persons_page {
    rewrite * /frontend/pages/persons.html
    file_server
  }

  @html_pages path /index.html /404.html /bookings.html /booking.html /persons.html /marketing_tour.html /marketing_tours.html /standard-tours.html /standard-tour.html /settings.html /emergency.html /privacy.html /traveler-details.html
  handle @html_pages {
    rewrite * /frontend/pages{path}
    file_server
  }

  @staging_access path /staging-access/*
  handle @staging_access {
    reverse_proxy host.docker.internal:8789
  }

  @protected not path /staging-access/* /api/whatsapp/webhook /integrations/meta/webhook /site.webmanifest /assets/* /frontend/scripts/* /frontend/data/* /frontend/Generated/* /shared/*
  forward_auth @protected host.docker.internal:8789 {
    uri /staging-access/check
  }

  @robots path /robots.txt
  rewrite @robots /robots-staging.txt

  @backend path /auth/* /api/* /public/v1/* /integrations/*
  handle @backend {
    reverse_proxy host.docker.internal:8789
  }

  @manifest path /site.webmanifest
  header @manifest Content-Type "application/manifest+json"

  handle {
    @existing_site_file file {
      try_files {path} {path}/index.html
    }
    handle @existing_site_file {
      file_server {
        hide /srv/.git /srv/.gitignore /srv/backend /srv/deploy /srv/documentation /srv/scripts /srv/docker-compose*.yml /srv/.env* /srv/README* /srv/AGENTS.md
      }
    }

    error 404
  }
}

api-staging.asiatravelplan.com {
  import security_headers
  import noindex_headers
  encode zstd gzip
  reverse_proxy host.docker.internal:8789
}

auth-staging.asiatravelplan.com {
  import security_headers
  import noindex_headers
  encode zstd gzip
  reverse_proxy host.docker.internal:8083
}
