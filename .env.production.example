PORT=8787
CORS_ORIGIN=https://asiatravelplan.com

KEYCLOAK_ENABLED=true
KEYCLOAK_BASE_URL=https://asiatravelplan.com/keycloak
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=asiatravelplan-backend
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_PRODUCTION_KEYCLOAK_CLIENT_SECRET
KEYCLOAK_REDIRECT_URI=https://asiatravelplan.com/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=https://asiatravelplan.com/
KEYCLOAK_ALLOWED_ROLES=atp_admin,atp_manager,atp_accountant,atp_staff,atp_tour_editor
KEYCLOAK_GLOBAL_LOGOUT=true
RETURN_TO_ALLOWED_ORIGINS=https://asiatravelplan.com

KEYCLOAK_ADMIN=administrator
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_PRODUCTION_KEYCLOAK_ADMIN_PASSWORD
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=CHANGE_ME_PRODUCTION_POSTGRES_PASSWORD

MOBILE_MIN_SUPPORTED_APP_VERSION=1.0.0
MOBILE_LATEST_APP_VERSION=1.0.0
MOBILE_FORCE_UPDATE=false

BOOKING_CONFIRMATION_TOKEN_SECRET=CHANGE_ME_PRODUCTION_BOOKING_CONFIRMATION_TOKEN_SECRET
TRAVELER_DETAILS_TOKEN_SECRET=CHANGE_ME_PRODUCTION_TRAVELER_DETAILS_TOKEN_SECRET

META_WEBHOOK_ENABLED=false
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
WHATSAPP_WEBHOOK_ENABLED=false
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION_ID=
OPENAI_MODEL=gpt-4.1
OPENAI_TRANSLATION_MODEL=gpt-4.1
GOOGLE_TRANSLATE_FALLBACK_ENABLED=true
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_IMPERSONATED_EMAIL=
